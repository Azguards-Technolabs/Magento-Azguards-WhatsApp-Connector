<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job instance="Azguards\WhatsAppConnect\Cron\SendAbandonedCart" method="execute" name="send_abandoned_cart_whatsapp">
            <schedule>* * * * *</schedule>
        </job>
        <job instance="Azguards\WhatsAppConnect\Cron\SyncTemplates" method="execute" name="azguards_whatsapp_template_sync">
            <schedule>0 * * * *</schedule>
        </job>
    </group>
</config>
