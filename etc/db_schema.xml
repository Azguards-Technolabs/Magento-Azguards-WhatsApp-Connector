<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="azguards_whatsapp_templates" resource="default" engine="innodb" comment="WhatsApp Templates Table">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="template_id" nullable="true" length="255" comment="ERP Template ID"/>
        <column xsi:type="varchar" name="template_name" nullable="false" length="50" comment="Template Name"/>
        <column xsi:type="varchar" name="template_type" nullable="false" length="50" default="TEXT" comment="Template Type"/>
        <column xsi:type="varchar" name="template_category" nullable="false" length="50" comment="Template Category"/>
        <column xsi:type="varchar" name="language" nullable="false" length="10" default="en_US" comment="Language Code (e.g. en_US)"/>
        <column xsi:type="varchar" name="status" nullable="false" length="20" default="PENDING" comment="Template Status (PENDING, APPROVED, REJECTED)"/>
        <column xsi:type="text" name="header" nullable="true" comment="Header Content (Text only)"/>
        <column xsi:type="varchar" name="header_format" nullable="true" length="20" default="TEXT" comment="Header Format (TEXT, IMAGE, VIDEO, DOCUMENT)"/>
        <column xsi:type="varchar" name="carousel_format" nullable="true" length="20" comment="Carousel Format (IMAGE, VIDEO)"/>
        <column xsi:type="text" name="header_image" nullable="true" comment="Header Image (Media ID or URL)"/>
        <column xsi:type="text" name="header_handle" nullable="true" comment="Meta Header Handle"/>
        <column xsi:type="text" name="body" nullable="false" comment="Body Content (Main message)"/>
        <column xsi:type="text" name="footer" nullable="true" comment="Footer Content (Small grey text)"/>
        <column xsi:type="varchar" name="button_type" nullable="true" length="50" comment="Legacy Button Type (Deprecated)"/>
        <column xsi:type="varchar" name="button_text" nullable="true" length="255" comment="Legacy Button Text (Deprecated)"/>
        <column xsi:type="varchar" name="button_url" nullable="true" length="255" comment="Legacy Button URL (Deprecated)"/>
        <column xsi:type="varchar" name="button_phone" nullable="true" length="255" comment="Legacy Button Phone (Deprecated)"/>
        <column xsi:type="text" name="buttons" nullable="true" comment="JSON encoded multiple buttons data"/>
        <column xsi:type="text" name="carousel_cards" nullable="true" comment="JSON encoded carousel cards"/>
        <column xsi:type="text" name="limited_time_offer" nullable="true" comment="JSON encoded LTO config"/>
        <column xsi:type="text" name="otp_details" nullable="true" comment="JSON encoded OTP details"/>
        <column xsi:type="text" name="body_examples_json" nullable="true" comment="JSON encoded body examples"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation Time"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Update Time"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="AZGUARDS_WHATSAPP_TEMPLATES_TEMPLATE_ID" indexType="btree">
            <column name="template_id"/>
        </index>
    </table>
    <table name="azguards_whatsapp_campaigns" resource="default" engine="innodb" comment="WhatsApp Campaigns Table">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="campaign_name" nullable="false" length="255" comment="Campaign Name"/>
        <column xsi:type="int" name="template_entity_id" unsigned="true" nullable="false" comment="Template Entity ID"/>
        <column xsi:type="varchar" name="target_type" nullable="false" length="32" default="groups" comment="Target Audience Type (groups/contacts)"/>
        <column xsi:type="text" name="customer_group_ids" nullable="true" comment="Customer Group IDs JSON"/>
        <column xsi:type="text" name="customer_ids" nullable="true" comment="Selected Customer IDs JSON"/>
        <column xsi:type="datetime" name="schedule_time" nullable="false" comment="Schedule Time"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending" comment="Campaign Status"/>
        <column xsi:type="text" name="variable_mapping" nullable="true" comment="JSON: per-variable static values entered by admin"/>
        <column xsi:type="varchar" name="media_handle" nullable="true" length="255" comment="Custom Media Handle (Document ID)"/>
        <column xsi:type="text" name="media_url" nullable="true" comment="Custom Local Media URL"/>
        <column xsi:type="int" name="sent_count" nullable="false" default="0" comment="Sent Count"/>
        <column xsi:type="int" name="failed_count" nullable="false" default="0" comment="Failed Count"/>
        <column xsi:type="datetime" name="executed_at" nullable="true" comment="Executed At"/>
        <column xsi:type="varchar" name="scheduler_id" nullable="true" length="255" comment="External Scheduler Job ID"/>
        <column xsi:type="varchar" name="trigger_type" nullable="true" length="32" comment="Trigger Type (EXPLICIT_DATE, CRON)"/>
        <column xsi:type="varchar" name="cron_expression" nullable="true" length="255" comment="Cron Expression for Recurring Campaigns"/>
        <column xsi:type="int" name="interval_in_months" nullable="true" comment="Interval in Months"/>
        <column xsi:type="int" name="interval_in_weeks" nullable="true" comment="Interval in Weeks"/>
        <column xsi:type="int" name="interval_in_days" nullable="true" comment="Interval in Days"/>
        <column xsi:type="varchar" name="time_zone" nullable="true" length="64" default="Asia/Calcutta" comment="IANA Timezone for WhatTalk scheduler"/>
        <column xsi:type="text" name="error_message" nullable="true" comment="Error Message"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation Time"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Update Time"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="AZGUARDS_WA_CAMPAIGN_TEMPLATE_ENTITY_ID_TEMPLATE_ENTITY_ID"
                    table="azguards_whatsapp_campaigns" column="template_entity_id"
                    referenceTable="azguards_whatsapp_templates" referenceColumn="entity_id" onDelete="CASCADE"/>
        <index referenceId="AZGUARDS_WA_CAMPAIGN_STATUS_SCHEDULE" indexType="btree">
            <column name="status"/>
            <column name="schedule_time"/>
        </index>
    </table>
    <table name="azguards_whatsapp_campaign_queue" resource="default" engine="innodb" comment="WhatsApp Campaign Queue Table">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="int" name="campaign_id" unsigned="true" nullable="true" comment="Campaign ID (Optional for event-driven messages)"/>
        <column xsi:type="int" name="template_entity_id" unsigned="true" nullable="true" comment="Template Entity ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true" comment="Customer ID (Optional if phone is provided)"/>
        <column xsi:type="varchar" name="recipient_phone" nullable="true" length="32" comment="Recipient Phone Number"/>
        <column xsi:type="text" name="variable_mapping" nullable="true" comment="JSON: per-variable values for this specific message"/>
        <column xsi:type="varchar" name="media_handle" nullable="true" length="255" comment="Custom Media Handle for this message"/>
        <column xsi:type="text" name="media_url" nullable="true" comment="Custom Local Media URL for this message"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending" comment="Item Status"/>
        <column xsi:type="text" name="error_message" nullable="true" comment="Error Message"/>
        <column xsi:type="timestamp" name="processed_at" nullable="true" comment="Processed At"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation Time"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="AZ_WA_QUEUE_CAMPAIGN_ID_FK"
                    table="azguards_whatsapp_campaign_queue" column="campaign_id"
                    referenceTable="azguards_whatsapp_campaigns" referenceColumn="entity_id" onDelete="CASCADE"/>
        <index referenceId="AZGUARDS_WA_QUEUE_STATUS_CAMPAIGN" indexType="btree">
            <column name="status"/>
            <column name="campaign_id"/>
        </index>
    </table>

    <table name="azguards_whatsapp_abandoned_cart_notify" resource="default" engine="innodb" comment="WhatsApp Abandoned Cart Notification Tracking">
        <column xsi:type="int" name="quote_id" unsigned="true" nullable="false" comment="Quote ID"/>
        <column xsi:type="int" name="store_id" unsigned="true" nullable="true" comment="Store ID"/>
        <column xsi:type="varchar" name="customer_email" nullable="true" length="255" comment="Customer Email"/>
        <column xsi:type="varchar" name="template_id" nullable="true" length="255" comment="WhatsApp External Template ID"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="sent" comment="sent/failed"/>
        <column xsi:type="text" name="error_message" nullable="true" comment="Last error message"/>
        <column xsi:type="timestamp" name="notified_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Notified At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="quote_id"/>
        </constraint>
        <index referenceId="AZGUARDS_WA_ABANDONED_CART_STATUS" indexType="btree">
            <column name="status"/>
        </index>
        <index referenceId="AZGUARDS_WA_ABANDONED_CART_EMAIL" indexType="btree">
            <column name="customer_email"/>
        </index>
    </table>
</schema>
