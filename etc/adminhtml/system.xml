<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="custom_tab" translate="label" sortOrder="100">
            <label>WhatsApp Conector</label>
        </tab>
        <section id="whatsApp_conector" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>WhatsApp Conector</label>
            <tab>custom_tab</tab>
            <resource>Azguards_WhatsAppConnect::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>General Configuration</label>
                <field id="enable" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>WhatsAppConector Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="base_url" translate="label comment" type="label" sortOrder="2" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API Base URL</label>
                    <comment>This value is read-only. Contact developer to change the API server.</comment>
                </field>
                <field id="authentication_api_url" translate="label" type="text" sortOrder="3" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Authentication Api URL</label>
                    <validate>required-entry</validate>
                </field>
                <field id="client_id" translate="label" type="text" sortOrder="4" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Client Id</label>
                    <validate>required-entry</validate>
                </field>
                <field id="client_secret_key" translate="label" type="text" sortOrder="5" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Client secret</label>
                    <validate>required-entry</validate>
                </field>
                <field id="grant_type" translate="label" type="text" sortOrder="6" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Grant Type</label>
                    <validate>required-entry</validate>
                </field>
                <field id="validate_button" translate="label" sortOrder="7" type="button" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Generate Authentication Credentials</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\System\Config\ValidateButton</frontend_model>
                </field>
            </group>
            
            <group id="user_registration" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>User Registration</label>
                <field id="searchable_dropdown" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
				    <label>Select with Search</label>
				    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\SelectTemplate</frontend_model>
				</field>
                <field id="media_handle" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Header Media (Image/Video/Doc)</label>
                    <comment>Shown only when selected template has a media header. Uploading here creates a reusable Media Handle for WhatsApp.</comment>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\MediaHandle</frontend_model>
                </field>

                <field id="index" translate="label comment tooltip" sortOrder="50" showInDefault="1" showInWebsite="1"
                       showInStore="0">
                    <label>Searchable content</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Config\Form\Field\UserRegistration</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                </field>
            </group>

             <group id="order_creation" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Order Creation</label>
                <field id="searchable_dropdown_order_create" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Select with Search</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\SelectTemplate</frontend_model>
                </field>
                <field id="media_handle" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Header Media (Image/Video/Doc)</label>
                    <comment>Only needed when selected template has a media header. Uploading here creates a reusable Media Handle for WhatsApp.</comment>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\MediaHandle</frontend_model>
                </field>
                <field id="order_create_variable" translate="label comment tooltip" sortOrder="50" showInDefault="1" showInWebsite="1"
                       showInStore="0">
                    <label>Searchable content</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Config\Form\Field\OrderCreate</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                </field>
            </group>

            <group id="order_invoice" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Order Invoice</label>
                <field id="searchable_dropdown_order_invoice" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Select with Search</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\SelectTemplate</frontend_model>
                </field>
                <field id="media_handle" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Header Media (Image/Video/Doc)</label>
                    <comment>Shown only when selected template has a media header. Uploading here creates a reusable Media Handle for WhatsApp.</comment>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\MediaHandle</frontend_model>
                </field>
                 <field id="order_invoice_variable" translate="label comment tooltip" sortOrder="50" showInDefault="1" showInWebsite="1"
                       showInStore="0">
                    <label>Searchable content</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Config\Form\Field\OrderInvoice</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                </field>
            </group>

            <group id="order_shipment" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Order Shipment</label>
                <field id="searchable_dropdown_order_shipment" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Select with Search</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\SelectTemplate</frontend_model>
                </field>
                <field id="media_handle" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Header Media (Image/Video/Doc)</label>
                    <comment>Shown only when selected template has a media header. Uploading here creates a reusable Media Handle for WhatsApp.</comment>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\MediaHandle</frontend_model>
                </field>
                <field id="order_shipment_variable" translate="label comment tooltip" sortOrder="50" showInDefault="1" showInWebsite="1"
                       showInStore="0">
                    <label>Searchable content</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Config\Form\Field\OrderShipment</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                </field>
            </group>

            <group id="order_cancellation" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Order Cancellation</label>
                <field id="searchable_dropdown_order_cancellation" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Select with Search</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\SelectTemplate</frontend_model>
                </field>
                <field id="media_handle" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Header Media (Image/Video/Doc)</label>
                    <comment>Shown only when selected template has a media header. Uploading here creates a reusable Media Handle for WhatsApp.</comment>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\MediaHandle</frontend_model>
                </field>
                <field id="order_cancellation_variable" translate="label comment tooltip" sortOrder="50" showInDefault="1" showInWebsite="1"
                       showInStore="0">
                    <label>Searchable content</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Config\Form\Field\OrderCancellation</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                </field>
            </group>

            <group id="order_credit_memo" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Order Credit Memo</label>
                <field id="searchable_dropdown_order_credit_memo" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Select with Search</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\SelectTemplate</frontend_model>
                </field>
                <field id="media_handle" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Header Media (Image/Video/Doc)</label>
                    <comment>Shown only when selected template has a media header. Uploading here creates a reusable Media Handle for WhatsApp.</comment>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\MediaHandle</frontend_model>
                </field>
                <field id="order_credit_memo_variable" translate="label comment tooltip" sortOrder="50" showInDefault="1" showInWebsite="1"
                       showInStore="0">
                    <label>Searchable content</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Config\Form\Field\OrderCreditMemo</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                </field>
            </group>

            <group id="abandon_cart" translate="label" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Abandoned Cart</label>

                <field id="enable" translate="label" type="select" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Abandoned Cart WhatsApp</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="abandon_after_minutes" translate="label comment" type="text" sortOrder="6" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Consider Abandoned After (minutes)</label>
                    <comment>Quotes updated before now-minus-this value are treated as abandoned. Recommended: 60.</comment>
                    <validate>validate-number validate-greater-than-zero</validate>
                </field>

                <field id="max_per_run" translate="label comment" type="text" sortOrder="7" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Max Quotes Per Cron Run</label>
                    <comment>Safety limit to avoid sending too many messages per run. Recommended: 50.</comment>
                    <validate>validate-number validate-greater-than-zero</validate>
                </field>

                <field id="searchable_dropdown_abandon_cart" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Select with Search</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\SelectTemplate</frontend_model>
                </field>

                <field id="media_handle" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Header Media (Image/Video/Doc)</label>
                    <comment>Only needed when selected template has a media header. Uploading here creates a reusable Media Handle for WhatsApp.</comment>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Form\Field\MediaHandle</frontend_model>
                </field>

                <field id="abandoned_cart_variable" translate="label comment tooltip" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Searchable content</label>
                    <frontend_model>Azguards\WhatsAppConnect\Block\Adminhtml\Config\Form\Field\AbandonCart</frontend_model>
                    <backend_model>Magento\Config\Model\Config\Backend\Serialized\ArraySerialized</backend_model>
                </field>
            </group>

             <group id="cron" translate="label" type="text" sortOrder="70" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Cron Configuration</label>
                <comment>Set how often each background sync job should run (in minutes). The system automatically converts this into a valid cron schedule.</comment>

                <!-- Campaign Sync: Fetches the latest status of all campaigns from the external WhatTalk scheduler API -->
                <field id="campaign_sync_schedule" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Campaign Sync (minutes)</label>
                    <comment>How often Magento polls WhatTalk for updated campaign statuses. Enter a number (e.g. 1 = every minute, 5 = every 5 minutes). Default: 1</comment>
                    <backend_model>Azguards\WhatsAppConnect\Model\Config\Backend\CronMinutes</backend_model>
                    <validate>required-entry validate-number validate-greater-than-zero</validate>
                </field>

                <!-- Contact Sync: Pushes unsynced customer WhatsApp profiles to the connector contact store -->
                <field id="contact_sync_schedule" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Contact Sync (minutes)</label>
                    <comment>How often unsynced customers are pushed to the WhatTalk contact store. Enter a number (e.g. 60 = every 60 minutes). Default: 1</comment>
                    <backend_model>Azguards\WhatsAppConnect\Model\Config\Backend\CronMinutes</backend_model>
                    <validate>required-entry validate-number validate-greater-than-zero</validate>
                </field>

                <!-- Template Sync: Pulls the latest approved WhatsApp templates from the connector into Magento -->
                <field id="template_sync_schedule" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Template Sync (minutes)</label>
                    <comment>How often approved WhatsApp templates are pulled from WhatTalk into Magento. Enter a number (e.g. 60 = every 60 minutes). Recommended: 60. Default: 1</comment>
                    <backend_model>Azguards\WhatsAppConnect\Model\Config\Backend\CronMinutes</backend_model>
                    <validate>required-entry validate-number validate-greater-than-zero</validate>
                </field>
            </group>
           
        </section>
    </system>
</config>
