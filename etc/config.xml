<?xml version="1.0"?>
     <config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
        <default>
            <whatsApp_conector>
                <general>
                    <base_url>https://whatatalk-api.azguardstech.com/</base_url>
                    <authentication_api_url>https://whatatalk-api.azguardstech.com/realms/azguards-whatsapp/protocol/openid-connect/token</authentication_api_url>
                </general>
                <abandon_cart>
                    <enable>0</enable>
                    <abandon_after_minutes>60</abandon_after_minutes>
                    <max_per_run>50</max_per_run>
                </abandon_cart>
                <cron>
                    <campaign_sync_schedule>* * * * *</campaign_sync_schedule>
                    <contact_sync_schedule>* * * * *</contact_sync_schedule>
                    <template_sync_schedule>* * * * *</template_sync_schedule>
                </cron>
            </whatsApp_conector>
            <whatsapp_template>
                <order_template>
                    <event_code>order_created</event_code>
                    <template_name></template_name>
                    <category>Utility</category>
                    <language>en_US</language>
                    <header_type>none</header_type>
                    <header_text></header_text>
                    <header_handle></header_handle>
                    <header_image></header_image>
                    <body_template></body_template>
                    <footer_template></footer_template>
                    <buttons_json>[]</buttons_json>
                </order_template>
            </whatsapp_template>
        </default>
    </config>
