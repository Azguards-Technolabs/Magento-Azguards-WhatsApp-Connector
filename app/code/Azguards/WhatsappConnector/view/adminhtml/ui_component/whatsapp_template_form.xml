<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">whatsapp_template_form.whatsapp_template_form_data_source</item>
            <item name="deps" xsi:type="string">whatsapp_template_form.whatsapp_template_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Template Information</item>
        <item name="config" xsi:type="array">
            <item name="dataScope" xsi:type="string">data</item>
            <item name="namespace" xsi:type="string">whatsapp_template_form</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
        <item name="buttons" xsi:type="array">
            <item name="back" xsi:type="string">Azguards\WhatsappConnector\Block\Adminhtml\Template\Edit\BackButton</item>
            <item name="delete" xsi:type="string">Azguards\WhatsappConnector\Block\Adminhtml\Template\Edit\DeleteButton</item>
            <item name="save" xsi:type="string">Azguards\WhatsappConnector\Block\Adminhtml\Template\Edit\SaveButton</item>
        </item>
    </argument>
    <dataSource name="whatsapp_template_form_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">Azguards\WhatsappConnector\Model\Template\DataProvider</argument>
            <argument name="name" xsi:type="string">whatsapp_template_form_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">template_id</argument>
            <argument name="requestFieldName" xsi:type="string">template_id</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="submit_url" xsi:type="url" path="*/*/save"/>
                </item>
            </argument>
        </argument>
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
    </dataSource>

    <fieldset name="template_details">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Template Details</item>
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="opened" xsi:type="boolean">true</item>
            </item>
        </argument>
        <field name="template_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">template</item>
                </item>
            </argument>
        </field>
        <field name="template_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Template Name</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">template</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                        <item name="pattern" xsi:type="string">^[a-z0-9_]{3,50}$</item>
                        <item name="validate-length" xsi:type="boolean">true</item>
                        <item name="min_text_length" xsi:type="number">3</item>
                        <item name="max_text_length" xsi:type="number">50</item>
                    </item>
                    <item name="notice" xsi:type="string" translate="true">3-50 chars, lowercase, numbers, underscores only. E.g., order_update_1</item>
                </item>
            </argument>
        </field>
        <field name="template_type">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Template Type</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="source" xsi:type="string">template</item>
                    <item name="options" xsi:type="array">
                        <item name="0" xsi:type="array">
                            <item name="value" xsi:type="string">TEXT</item>
                            <item name="label" xsi:type="string" translate="true">TEXT</item>
                        </item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="template_category">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Category</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="source" xsi:type="string">template</item>
                    <item name="options" xsi:type="array">
                        <item name="0" xsi:type="array">
                            <item name="value" xsi:type="string">Marketing</item>
                            <item name="label" xsi:type="string" translate="true">Marketing</item>
                        </item>
                        <item name="1" xsi:type="array">
                            <item name="value" xsi:type="string">Utility</item>
                            <item name="label" xsi:type="string" translate="true">Utility</item>
                        </item>
                        <item name="2" xsi:type="array">
                            <item name="value" xsi:type="string">Authentication</item>
                            <item name="label" xsi:type="string" translate="true">Authentication</item>
                        </item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="language">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Language</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">template</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                    <item name="notice" xsi:type="string" translate="true">E.g., en_US</item>
                </item>
            </argument>
        </field>
    </fieldset>

    <fieldset name="header_section">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Header Section (Optional)</item>
                <item name="collapsible" xsi:type="boolean">true</item>
            </item>
        </argument>
        <field name="header_text">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Header Text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">template</item>
                    <item name="notice" xsi:type="string" translate="true">Allowed variable: {{1}}</item>
                </item>
            </argument>
        </field>
    </fieldset>

    <fieldset name="body_section">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Body Section (Required)</item>
                <item name="collapsible" xsi:type="boolean">true</item>
                <item name="opened" xsi:type="boolean">true</item>
            </item>
        </argument>
        <field name="body_text">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Body Text</item>
                    <item name="formElement" xsi:type="string">textarea</item>
                    <item name="source" xsi:type="string">template</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                    <item name="notice" xsi:type="string" translate="true">Allowed variables: {{1}}, {{2}}, {{3}}</item>
                </item>
            </argument>
        </field>
    </fieldset>

    <fieldset name="footer_section">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Footer Section (Optional)</item>
                <item name="collapsible" xsi:type="boolean">true</item>
            </item>
        </argument>
        <field name="footer_text">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Footer Text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">template</item>
                    <item name="notice" xsi:type="string" translate="true">E.g., Reply STOP to unsubscribe.</item>
                </item>
            </argument>
        </field>
    </fieldset>

    <fieldset name="buttons_section">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Buttons Section (Optional)</item>
                <item name="collapsible" xsi:type="boolean">true</item>
            </item>
        </argument>
        <field name="button_type">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Button Type</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="source" xsi:type="string">template</item>
                    <item name="options" xsi:type="array">
                        <item name="0" xsi:type="array">
                            <item name="value" xsi:type="string"></item>
                            <item name="label" xsi:type="string" translate="true">None</item>
                        </item>
                        <item name="1" xsi:type="array">
                            <item name="value" xsi:type="string">quick_reply</item>
                            <item name="label" xsi:type="string" translate="true">Quick Reply</item>
                        </item>
                        <item name="2" xsi:type="array">
                            <item name="value" xsi:type="string">url</item>
                            <item name="label" xsi:type="string" translate="true">URL</item>
                        </item>
                        <item name="3" xsi:type="array">
                            <item name="value" xsi:type="string">phone</item>
                            <item name="label" xsi:type="string" translate="true">Phone</item>
                        </item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="button_text">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Button Text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">template</item>
                </item>
            </argument>
        </field>
        <field name="button_url">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Button URL</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">template</item>
                </item>
            </argument>
        </field>
        <field name="button_phone">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Button Phone</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="source" xsi:type="string">template</item>
                </item>
            </argument>
        </field>
    </fieldset>
</form>
