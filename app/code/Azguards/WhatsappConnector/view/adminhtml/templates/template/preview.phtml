<?php
$template = $block->getData('template_data');

function replaceVariables($text) {
    if (!$text) return '';
    $text = str_replace('{{1}}', '<strong>[Sample 1]</strong>', $text);
    $text = str_replace('{{2}}', '<strong>[Sample 2]</strong>', $text);
    $text = str_replace('{{3}}', '<strong>[Sample 3]</strong>', $text);
    return nl2br(htmlspecialchars($text, ENT_QUOTES, 'UTF-8'));
}
?>

<div class="whatsapp-preview-container" style="max-width: 400px; margin: 20px auto; border: 1px solid #ddd; border-radius: 10px; padding: 15px; background: #e5ddd5; font-family: Helvetica, Arial, sans-serif;">
    <div class="message-box" style="background: #fff; border-radius: 8px; padding: 10px; box-shadow: 0 1px 1px rgba(0,0,0,0.1);">
        <?php if ($template->getHeaderText()): ?>
            <div class="header" style="font-weight: bold; margin-bottom: 10px;">
                <?= replaceVariables($template->getHeaderText()) ?>
            </div>
        <?php endif; ?>

        <div class="body" style="font-size: 14px; line-height: 1.4; color: #111;">
            <?= replaceVariables($template->getBodyText()) ?>
        </div>

        <?php if ($template->getFooterText()): ?>
            <div class="footer" style="font-size: 12px; color: #888; margin-top: 10px;">
                <?= htmlspecialchars($template->getFooterText()) ?>
            </div>
        <?php endif; ?>
    </div>

    <?php if ($template->getButtonType()): ?>
        <div class="buttons" style="margin-top: 10px; display: flex; flex-direction: column; gap: 5px;">
            <div class="button" style="background: #fff; text-align: center; padding: 10px; border-radius: 5px; color: #007bff; font-weight: bold; cursor: pointer;">
                <?php
                    $type = htmlspecialchars($template->getButtonType());
                    $text = htmlspecialchars($template->getButtonText());
                    $url = htmlspecialchars($template->getButtonUrl());
                    $phone = htmlspecialchars($template->getButtonPhone());

                    if ($type == 'url') {
                        echo "🌐 $text <br><small style='color:#888;'>($url)</small>";
                    } elseif ($type == 'phone') {
                        echo "📞 $text <br><small style='color:#888;'>($phone)</small>";
                    } else {
                        echo "↩️ $text";
                    }
                ?>
            </div>
        </div>
    <?php endif; ?>
</div>
