                                    <script>
                                        document.addEventListener('DOMContentLoaded', function() {
                                            const tabs = document.querySelectorAll('.wa-var-tab-btn');
                                            const panels = document.querySelectorAll('.wa-var-panel');
                                            
                                            tabs.forEach(tab => {
                                                tab.addEventListener('click', function(e) {
                                                    e.stopPropagation();
                                                    e.preventDefault();
                                                    
                                                    tabs.forEach(t => t.classList.remove('active'));
                                                    panels.forEach(p => p.classList.remove('active'));
                                                    
                                                    this.classList.add('active');
                                                    const target = document.getElementById(this.getAttribute('data-target'));
                                                    if(target) target.classList.add('active');
                                                });
                                            });
                                            
                                            const menu = document.getElementById('wa-variable-menu');
                                            menu.addEventListener('click', function(e) {
                                                if (!e.target.closest('.wa-var-item') && !e.target.closest('.wa-var-tab-btn')) {
                                                    e.stopPropagation();
                                                }
                                            });
                                        });
                                    </script>
