$groups = $block->getVariableGroups();
?>
<div id="wa-variable-selector-root" class="wa-template-card wa-template-card--full wa-template-card--variables">
    <h3 class="wa-template-card__title"><?= $block->escapeHtml(__('Body Variables')) ?></h3>
    <p class="wa-template-card__subtitle">
        <?= $block->escapeHtml(__('Open only the variable group you need and insert it into the body at the cursor position.')) ?>
