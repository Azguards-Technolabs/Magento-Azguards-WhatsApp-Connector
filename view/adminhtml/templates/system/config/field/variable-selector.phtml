    <label class="wa-variable-master-toggle">
        <input type="checkbox" id="wa-variable-toggle"/>
        <span><?= $block->escapeHtml(__('Enable Variable Selection')) ?></span>
    </label>
    <div class="wa-variable-groups" id="wa-variable-panel" style="display:none;">
