<script>
require(['jquery', 'select2', 'mage/translate'], function($, select2, $t) {
    $(function() {
        var config = window.whatsappCampaignConfig || {};
        var $contacts = $('#campaign_custom_contacts');
        
        function formatResult(state) {
            if (!state.id) return state.text;
            
            var name = state.name || state.text;
            var email = state.email || '';
            var phone = state.phone || '';
            
            var $container = $(
                '<div class="wa-select2-result">' +
                    '<div class="wa-result-icon"><i class="fa fa-user"></i></div>' +
                    '<div class="wa-result-info">' +
                        '<div class="wa-result-name">' + name + '</div>' +
                        '<div class="wa-result-sub">' +
                            (phone
                                ? '<span class="wa-result-phone"><i class="fa fa-whatsapp"></i> ' + phone + '</span>'
                                : '') +
                            (email
                                ? '<span class="wa-result-email"><i class="fa fa-envelope-o"></i> ' + email + '</span>'
                                : '') +
                        '</div>' +
                    '</div>' +
                '</div>'
            );
            return $container;
        }

        $contacts.select2({
            placeholder: $t('Search and select contacts...'),
            minimumInputLength: 0,
            allowClear: true,
            templateResult: formatResult,
            ajax: {
                url: config.searchUrl,
                dataType: 'json',
                delay: 250,
                data: function (params) {
                    return { 
                        q: params.term, 
                        page: params.page || 1,
                        form_key: window.FORM_KEY,
                        isAjax: true
                    };
                },
                processResults: function (data) {
                    return {
                        results: data.results || [],
                        pagination: data.pagination || {}
                    };
                },
                cache: true
            }
        });

        // Clear All action
        $('#wa-clear-contacts').on('click', function() {
            $contacts.val(null).trigger('change');
        });

        // Pre-fill existing contacts if any (Senior Level Edit Support)
        require(['uiRegistry'], function(registry) {
            registry.get('whatsapp_campaign_form.whatsapp_campaign_form.general.customer_ids', function(component) {
                var currentIds = component.value();
                if (currentIds) {
                    $.ajax({
                        url: config.searchUrl,
                        dataType: 'json',
                        data: {
                            ids: currentIds,
                            form_key: window.FORM_KEY,
                            isAjax: true
                        }
                    }).done(function(data) {
                        if (data && data.results) {
                            data.results.forEach(function(item) {
                                var option = new Option(item.text, item.id, true, true);
                                option.name = item.name;
                                option.email = item.email;
                                option.phone = item.phone;
                                $contacts.append(option).trigger('change');
                            });
                        }
                    });
                }
            });
        });

        // Sync Select2 value to the hidden field
        $contacts.on('change', function() {
            require(['uiRegistry'], function(registry) {
                registry.get('whatsapp_campaign_form.whatsapp_campaign_form.general.customer_ids', function(component) {
                    var val = $contacts.val();
                    var newValue = val ? (Array.isArray(val) ? val.join(',') : val) : '';
                    if (component.value() !== newValue) {
                        component.value(newValue);
                    }
                });
            });
        });
    });
});
</script>
