<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">whatsapp_campaigns_listing.whatsapp_campaigns_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Create Campaign</label>
            </button>
        </buttons>
        <spinner>whatsapp_campaign_columns</spinner>
        <deps>
            <dep>whatsapp_campaigns_listing.whatsapp_campaigns_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="whatsapp_campaigns_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Azguards_WhatsAppConnect::campaigns</aclResource>
        <dataProvider class="Azguards\WhatsAppConnect\Ui\DataProvider\Campaign\Grid\DataProvider" name="whatsapp_campaigns_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <massaction name="listing_massaction">
            <argument name="data" xsi:type="array">
                <item name="data" xsi:type="array">
                    <item name="selectProvider" xsi:type="string">whatsapp_campaigns_listing.whatsapp_campaigns_listing.whatsapp_campaign_columns.ids</item>
                    <item name="indexField" xsi:type="string">entity_id</item>
                </item>
            </argument>
            <action name="delete">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="type" xsi:type="string">delete</item>
                        <item name="label" xsi:type="string" translate="true">Delete</item>
                        <item name="url" xsi:type="url" path="whatsappconnect/campaign/massDelete"/>
                        <item name="confirm" xsi:type="array">
                            <item name="title" xsi:type="string" translate="true">Delete Campaigns</item>
                            <item name="message" xsi:type="string" translate="true">Are you sure you want to delete the selected campaigns?</item>
                        </item>
                    </item>
                </argument>
            </action>
        </massaction>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="whatsapp_campaign_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
            </settings>
        </column>
        <column name="campaign_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Campaign Name</label>
            </settings>
        </column>
        <column name="template_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Template</label>
            </settings>
        </column>
        <column name="customer_group_ids" class="Azguards\WhatsAppConnect\Ui\Component\Listing\Column\CampaignCustomerGroups">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer Groups</label>
            </settings>
        </column>
        <column name="schedule_time" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Schedule Time</label>
            </settings>
        </column>
        <column name="status">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
                <options class="Azguards\WhatsAppConnect\Model\Source\CampaignStatus"/>
            </settings>
        </column>
        <column name="sent_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Sent</label>
            </settings>
        </column>
        <column name="failed_count">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Failed</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Azguards\WhatsAppConnect\Ui\Component\Listing\Column\CampaignActions">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
