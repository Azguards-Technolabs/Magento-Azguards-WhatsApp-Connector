<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <settings>
        <buttons>
            <button name="whatsapp_bulk_sync">
                <url path="whatsappconnect/customer/syncAll"/>
                <class>action-secondary</class>
                <label translate="true">Bulk Sync WhatsApp</label>
            </button>
        </buttons>
    </settings>
    <listingToolbar name="listing_top">
        <massaction name="listing_massaction">
            <action name="whatsapp_sync">
                <settings>
                    <type>whatsapp_sync</type>
                    <label translate="true">Sync WhatsApp Contacts</label>
                    <url path="whatsappconnect/customer/massSync"/>
                    <confirm>
                        <title translate="true">Sync WhatsApp Contacts</title>
                        <message translate="true">Are you sure you want to sync selected customers to WhatsApp?</message>
                    </confirm>
                </settings>
            </action>
        </massaction>
    </listingToolbar>
</listing>
