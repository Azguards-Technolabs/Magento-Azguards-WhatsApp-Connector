<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">whatsapp_template_form.whatsapp_template_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Template Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="Azguards\WhatsAppConnect\Block\Adminhtml\Template\Edit\SaveButton"/>
            <button name="save_and_continue" class="Azguards\WhatsAppConnect\Block\Adminhtml\Template\Edit\SaveAndContinueButton"/>
            <button name="delete" class="Azguards\WhatsAppConnect\Block\Adminhtml\Template\Edit\DeleteButton"/>
            <button name="back" class="Azguards\WhatsAppConnect\Block\Adminhtml\Template\Edit\BackButton"/>
        </buttons>
        <namespace>whatsapp_template_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>whatsapp_template_form.whatsapp_template_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="whatsapp_template_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="whatsappconnect/template/save"/>
        </settings>
        <dataProvider class="Azguards\WhatsAppConnect\Model\Template\DataProvider" name="whatsapp_template_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">Template Details</label>
        </settings>
        <field name="entity_id" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">template</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
            </settings>
        </field>
        <field name="template_name" formElement="input">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-identifier" xsi:type="boolean">false</rule>
                    <rule name="validate-pattern" xsi:type="string">^[a-z0-9_]{3,50}$</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Template Name</label>
                <notice translate="true">The template name must be unique and follow specific formatting rules (lowercase, numbers, underscores).</notice>
            </settings>
        </field>
        <field name="template_type" formElement="select" component="Azguards_WhatsAppConnect/js/form/element/template-type">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Template Type</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Azguards\WhatsAppConnect\Model\Source\TemplateType"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <container name="image_category_notice">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="additionalClasses" xsi:type="string">message message-success</item>
                </item>
            </argument>
            <htmlContent name="html_content">
                <block name="image_notice_block" class="Magento\Framework\View\Element\Template" template="Azguards_WhatsAppConnect::form/image_notice.phtml"/>
            </htmlContent>
        </container>
        <field name="template_category" formElement="select">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Template Category</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Azguards\WhatsAppConnect\Model\Source\TemplateCategory"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="language" formElement="select">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Language Code</label>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Azguards\WhatsAppConnect\Model\Source\Language"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="header_section">
        <settings>
            <label translate="true">HEADER (Optional)</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
            <additionalClasses>
                <class name="whatsapp-header-section">true</class>
            </additionalClasses>
        </settings>
        <field name="header_format" formElement="select" component="Azguards_WhatsAppConnect/js/form/element/header-format">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Header Format</label>
                <dataScope>header_format</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Azguards\WhatsAppConnect\Model\Source\HeaderFormat"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="carousel_format" formElement="select">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Carousel Format</label>
                <dataScope>carousel_format</dataScope>
                <visible>false</visible>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Azguards\WhatsAppConnect\Model\Source\HeaderFormat"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="header" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Header Text Content</label>
                <notice translate="true">Max 60 characters. You can use variables like {{name}}.</notice>
                <imports>
                    <link name="visible">${ $.parentName }.header_format:textVisible</link>
                </imports>
            </settings>
        </field>
        <field name="header_media_upload" formElement="fileUploader" component="Azguards_WhatsAppConnect/js/form/element/media-uploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="documentIdField" xsi:type="string">${ $.parentName }.header_handle</item>
                    <item name="previewLinkField" xsi:type="string">${ $.parentName }.header_image</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Header Media</label>
                <notice translate="true">Upload header media (Image, Video, or Document). Required if format is not TEXT.</notice>
                <visible>false</visible>
                <imports>
                    <link name="visible">${ $.parentName }.header_format:mediaVisible</link>
                </imports>
            </settings>
            <formElements>
                <fileUploader>
                    <settings>
                        <allowedExtensions>jpg jpeg png mp4 3gp pdf doc docx xls xlsx ppt pptx</allowedExtensions>
                        <maxFileSize>10485760</maxFileSize>
                        <previewTmpl>ui/form/element/uploader/preview</previewTmpl>
                        <uploaderConfig>
                            <param xsi:type="string" name="url">whatsappconnect/template/upload</param>
                        </uploaderConfig>
                    </settings>
                </fileUploader>
            </formElements>
        </field>
        <field name="header_handle" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Meta Header Handle</label>
                <visible>false</visible>
            </settings>
        </field>
        <field name="header_image" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Header Preview Link</label>
                <visible>false</visible>
            </settings>
        </field>
    </fieldset>
    <fieldset name="body_section">
        <settings>
            <label translate="true">BODY (Required)</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="body" formElement="textarea">
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Body Content (Required)</label>
                <notice translate="true">You can use variables like {{name}} or {{order_id}}. These will be automatically extracted.</notice>
            </settings>
        </field>
    </fieldset>
    <fieldset name="variables_info">
        <settings>
            <label translate="true">Variables (Read-only)</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
        </settings>
        <field name="detected_variables" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Detected Variables</label>
                <disabled>true</disabled>
                <notice translate="true">Extracted from header/body/footer content.</notice>
            </settings>
        </field>
        <field name="config_variable_mapping_summary" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Configured Mapping</label>
                <disabled>true</disabled>
                <notice translate="true">Shows System Configuration mapping if this template is selected for an event.</notice>
            </settings>
        </field>
    </fieldset>
    <fieldset name="footer_section">
        <settings>
            <label translate="true">FOOTER (Optional)</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
            <additionalClasses>
                <class name="whatsapp-footer-section">true</class>
            </additionalClasses>
        </settings>
        <field name="footer" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Footer Content</label>
                <notice translate="true">Add a short footer note (Optional). Max 60 characters.</notice>
            </settings>
        </field>
    </fieldset>
    <fieldset name="buttons_section">
        <settings>
            <label translate="true">Buttons Section</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
            <additionalClasses>
                <class name="whatsapp-buttons-section">true</class>
            </additionalClasses>
        </settings>
        <dynamicRows name="buttons">
            <settings>
                <notice translate="true">WhatsApp templates support a maximum of 3 buttons (Quick Replies or Website/Call buttons).</notice>
                <addButtonLabel translate="true">Add Button</addButtonLabel>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <componentType>dynamicRows</componentType>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>
                <field name="type" formElement="select">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Type</label>
                        <dataScope>type</dataScope>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options class="Azguards\WhatsAppConnect\Model\Source\ButtonType"/>
                            </settings>
                        </select>
                    </formElements>
                </field>
                <field name="text" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Text</label>
                        <dataScope>text</dataScope>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                            <rule name="max_text_length" xsi:type="number">25</rule>
                        </validation>
                    </settings>
                </field>
                <field name="value" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">URL / Phone Number</label>
                        <dataScope>value</dataScope>
                        <notice translate="true">URL: http://example.com | Phone: +919876543210 (with country code). Leave empty for Quick Reply.</notice>
                    </settings>
                </field>
                <actionDelete name="actionDelete">
                    <settings>
                        <componentType>actionDelete</componentType>
                        <dataType>text</dataType>
                        <label translate="true">Actions</label>
                    </settings>
                </actionDelete>
            </container>
        </dynamicRows>
    </fieldset>
    <fieldset name="carousel_section">
        <settings>
            <label translate="true">Carousel Cards (For Carousel Template)</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
            <additionalClasses>
                <class name="whatsapp-carousel-section">true</class>
            </additionalClasses>
        </settings>
        <dynamicRows name="carousel_cards">
            <settings>
                <notice translate="true">Add up to 10 cards.</notice>
                <addButtonLabel translate="true">Add Card</addButtonLabel>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <componentType>dynamicRows</componentType>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>

                <!-- ═══════════════════════════════════════════════ -->
                <!-- BODY (Required) - Each card must have body text -->
                <!-- ═══════════════════════════════════════════════ -->
                <field name="body" formElement="textarea">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Body Content</label>
                        <dataScope>body</dataScope>
                        <notice translate="true">Required. Card body text. Use {{1}}, {{2}} etc. for dynamic variables.</notice>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                </field>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- HEADER FORMAT - Select the type of media for this card -->
                <!-- ═══════════════════════════════════════════════════════ -->
                <field name="header_format" formElement="select">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Header Format</label>
                        <dataScope>header_format</dataScope>
                        <notice translate="true">Select the header media type for this card (IMAGE or VIDEO).</notice>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options class="Azguards\WhatsAppConnect\Model\Source\HeaderFormat"/>
                            </settings>
                        </select>
                    </formElements>
                </field>

                <!-- ═══════════════════════════════════════════════════════════════════════════ -->
                <!-- MEDIA UPLOAD - Upload the image/video for this card's header               -->
                <!-- Required when Header Format is IMAGE or VIDEO. Leave empty for TEXT cards. -->
                <!-- ═══════════════════════════════════════════════════════════════════════════ -->
                <field name="header_media_upload" formElement="fileUploader" component="Azguards_WhatsAppConnect/js/form/element/media-uploader">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="documentIdField" xsi:type="string">${ $.parentName }.header_handle</item>
                            <item name="previewLinkField" xsi:type="string">${ $.parentName }.header_image</item>
                        </item>
                    </argument>
                    <settings>
                        <label translate="true">Header Media Upload</label>
                        <notice translate="true">Upload an image or video for this card. Required if Header Format is IMAGE or VIDEO. Allowed: jpg, jpeg, png, mp4, 3gp.</notice>
                    </settings>
                    <formElements>
                        <fileUploader>
                            <settings>
                                <allowedExtensions>jpg jpeg png mp4 3gp</allowedExtensions>
                                <maxFileSize>10485760</maxFileSize>
                                <previewTmpl>ui/form/element/uploader/preview</previewTmpl>
                                <uploaderConfig>
                                    <param xsi:type="string" name="url">whatsappconnect/template/upload</param>
                                </uploaderConfig>
                            </settings>
                        </fileUploader>
                    </formElements>
                </field>

                <!-- Hidden: Stores uploaded media handle (auto-filled after upload) -->
                <field name="header_handle" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Header Handle</label>
                        <dataScope>header_handle</dataScope>
                        <visible>false</visible>
                    </settings>
                </field>

                <!-- Hidden: Stores uploaded media preview URL (auto-filled after upload) -->
                <field name="header_image" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Header Image URL</label>
                        <dataScope>header_image</dataScope>
                        <visible>false</visible>
                    </settings>
                </field>

                <!-- ══════════════════════════════════════════════════════════════════ -->
                <!-- BUTTONS - Each carousel card can have up to 2 buttons             -->
                <!-- Supported types: URL (website link) or QUICK_REPLY               -->
                <!-- ══════════════════════════════════════════════════════════════════ -->
                <dynamicRows name="buttons">
                    <settings>
                        <notice translate="true">Add up to 2 buttons per card (URL or Quick Reply).</notice>
                        <addButtonLabel translate="true">Add Button</addButtonLabel>
                        <additionalClasses>
                            <class name="admin__field-wide">true</class>
                        </additionalClasses>
                        <componentType>dynamicRows</componentType>
                    </settings>
                    <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                        <argument name="data" xsi:type="array">
                            <item name="config" xsi:type="array">
                                <item name="isTemplate" xsi:type="boolean">true</item>
                                <item name="is_collection" xsi:type="boolean">true</item>
                                <item name="componentType" xsi:type="string">container</item>
                            </item>
                        </argument>
                        <field name="type" formElement="select">
                            <settings>
                                <dataType>text</dataType>
                                <label translate="true">Button Type</label>
                                <dataScope>type</dataScope>
                                <validation>
                                    <rule name="required-entry" xsi:type="boolean">true</rule>
                                </validation>
                            </settings>
                            <formElements>
                                <select>
                                    <settings>
                                        <options class="Azguards\WhatsAppConnect\Model\Source\ButtonType"/>
                                    </settings>
                                </select>
                            </formElements>
                        </field>
                        <field name="text" formElement="input">
                            <settings>
                                <dataType>text</dataType>
                                <label translate="true">Button Text</label>
                                <dataScope>text</dataScope>
                                <notice translate="true">Button label shown to the user. Max 25 characters.</notice>
                                <validation>
                                    <rule name="required-entry" xsi:type="boolean">true</rule>
                                    <rule name="max_text_length" xsi:type="number">25</rule>
                                </validation>
                            </settings>
                        </field>
                        <field name="value" formElement="input">
                            <settings>
                                <dataType>text</dataType>
                                <label translate="true">URL / Phone Number</label>
                                <dataScope>value</dataScope>
                                <notice translate="true">URL: https://example.com | Phone: +919876543210 (with country code). Leave empty for Quick Reply.</notice>
                            </settings>
                        </field>
                        <actionDelete name="actionDelete">
                            <settings>
                                <componentType>actionDelete</componentType>
                                <dataType>text</dataType>
                                <label translate="true">Actions</label>
                            </settings>
                        </actionDelete>
                    </container>
                </dynamicRows>

                <actionDelete name="actionDelete">
                    <settings>
                        <componentType>actionDelete</componentType>
                        <dataType>text</dataType>
                        <label translate="true">Remove Card</label>
                    </settings>
                </actionDelete>
            </container>
        </dynamicRows>
    </fieldset>
</form>
